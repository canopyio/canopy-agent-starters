# Canopy auth — set ONE of these two combinations.

# Option A: MCP token (set automatically when you scaffold via the browser flow
# in `npx @canopy-ai/create-canopy-agent`). Recommended.
# CANOPY_MCP_TOKEN=canopy_mcp_xxxxxxxxxxxxxxxx
# CANOPY_MCP_URL=https://mcp.trycanopy.ai/mcp

# Option B: Org API key (paste-flow / hand-cloned scaffolds).
CANOPY_API_KEY=ak_live_xxxxxxxxxxxxxxxx

# Required either way.
CANOPY_AGENT_ID=agt_xxxxxxxx

# Required: Claude Agent SDK uses Anthropic's API.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
